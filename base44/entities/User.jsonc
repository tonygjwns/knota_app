{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "description": "The role of the user in the app",
      "enum": [
        "admin",
        "user"
      ]
    },
    "approval_status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ],
      "default": "pending",
      "description": "Admin approval status for this user"
    },
    "approved_by": {
      "type": "string",
      "description": "Admin user ID who approved/rejected"
    },
    "approved_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the user was approved"
    },
    "rejected_reason": {
      "type": "string",
      "description": "Reason for rejection"
    }
  },
  "required": [
    "role"
  ]
}