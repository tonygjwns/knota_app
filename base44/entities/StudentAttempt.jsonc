{
  "name": "StudentAttempt",
  "type": "object",
  "properties": {
    "student_id": {
      "type": "string",
      "description": "User ID of the student"
    },
    "student_email": {
      "type": "string",
      "description": "Email of the student"
    },
    "problem_id": {
      "type": "string",
      "description": "Problem ID from snapshot"
    },
    "problem_content": {
      "type": "string",
      "description": "Problem text (cached)"
    },
    "problem_domain": {
      "type": "string",
      "description": "Domain name"
    },
    "canvas_image_url": {
      "type": "string",
      "description": "Canvas drawing image URL"
    },
    "photo_url": {
      "type": "string",
      "description": "Uploaded photo URL"
    },
    "ocr_text": {
      "type": "string",
      "description": "Gemini OCR result markdown_text"
    },
    "ocr_corrected_text": {
      "type": "string",
      "description": "Student-corrected OCR text"
    },
    "claude_grade_json": {
      "type": "string",
      "description": "Full GradingOutput JSON string"
    },
    "score": {
      "type": "number",
      "description": "Score 0-100"
    },
    "correctness": {
      "type": "string",
      "enum": [
        "correct",
        "partial",
        "wrong"
      ],
      "description": "Overall correctness"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "duration_sec": {
      "type": "number"
    },
    "admin_review_status": {
      "type": "string",
      "enum": [
        "ok",
        "needs_correction",
        "skipped"
      ],
      "description": "Admin review status"
    },
    "admin_review_note": {
      "type": "string"
    },
    "assignment_id": {
      "type": "string",
      "description": "\uc18c\uc18d \uc219\uc81c ID (\uc790\uc720 \ud480\uc774\ub294 null)"
    },
    "attempt_type": {
      "type": "string",
      "enum": [
        "practice",
        "homework",
        "remediation_retry",
        "remediation_practice"
      ],
      "default": "practice",
      "description": "\uc2dc\ub3c4 \uc720\ud615"
    },
    "parent_attempt_id": {
      "type": "string",
      "description": "\ubcf4\uac15\uc758 \ubd80\ubaa8 \uc2dc\ub3c4 (1 \ucc28 \ud480\uc774) ID"
    },
    "target_tool_id": {
      "type": "string",
      "description": "\ubcf4\uac15 \uc911\uc778 \ub9e4\ub4ed tool_id"
    },
    "student_answer": {
      "type": "string",
      "description": "\ud559\uc0dd\uc774 \ub2f5\uc548 input \uce94\uc5d0 \uc785\ub825\ud55c \ub2f5\uc548 \ud14d\uc2a4\ud2b8 (\ub2e8\uc77c \uc22b\uc790 \ub610\ub294 \uc218\uc2dd). UX-1 \ud68c\ucc28\uc5d0\uc11c \ucc44\uc6cc\uc9d0."
    },
    "answer_check_result": {
      "type": "string",
      "enum": [
        "correct",
        "correct_via_solution",
        "wrong"
      ],
      "description": "Stage 1/2 \ucc44\uc810 \uacb0\uacfc \ubd84\ub958. correct = Stage 1 \ub2f5 \ub9e4\uce6d, correct_via_solution = Stage 2 \ud480\uc774\uc0c1 \uc815\ub2f5, wrong = Stage 3 \uae4a\uc774 \ucc44\uc810 \uc9c4\uc785. UX-1/UX-2 \ud68c\ucc28\uc5d0\uc11c \ucc44\uc6cc\uc9d0."
    },
    "tool_mapping_status": {
      "type": "string",
      "enum": [
        "pending",
        "done",
        "failed"
      ],
      "description": "\uc815\ub2f5 \uc2dc \ubc31\uadf8\ub77c\uc6b4\ub4dc \ub3c4\uad6c \ub9e4\ud551 \uc9c4\ud589 \uc0c1\ud0dc. UX-2 \ud68c\ucc28\uc5d0\uc11c \ucc44\uc6cc\uc9d0."
    },
    "review_requested": {
      "type": "boolean",
      "description": "\ud559\uc0dd\uc774 \uacb0\uacfc \ud654\uba74\uc5d0\uc11c '\uc774 \ucc44\uc810 \ub2e4\uc2dc \ubd10\uc8fc\uc138\uc694'\ub97c \ub204\ub978 \uacbd\uc6b0 true. \uac80\ud1a0 v2 \ud68c\ucc28\uc5d0 ResultView\uc5d0\uc11c \ucc44\uc6cc\uc9d0."
    },
    "review_request_note": {
      "type": "string",
      "description": "\ud559\uc0dd\uc774 \uac80\ud1a0 \uc694\uccad \uc2dc \ub0a8\uae34 \uba54\ubaa8. \uac80\ud1a0 v2 \ud68c\ucc28\uc5d0\uc11c \ucc44\uc6cc\uc9d0."
    },
    "review_resolved_at": {
      "type": "string",
      "format": "date-time",
      "description": "\uac15\uc0ac\uac00 \uac80\ud1a0\ub97c \uc644\ub8cc\ud55c \uc2dc\uac01. \uac80\ud1a0 v2 \ud68c\ucc28\uc5d0\uc11c \ucc44\uc6cc\uc9d0."
    },
    "teacher_review_json": {
      "type": "string",
      "description": "\uac15\uc0ac\uac00 \ub9e4\ub4ed\ubcc4\ub85c \ubcf4\uc815\ud55c \ucc44\uc810 \uacb0\uacfc JSON. claude_grade_json \uc6d0\ubcf8\uc740 \uc720\uc9c0, \uc774 \ud544\ub4dc\uc5d0 \ubcf4\uc815 \uacb0\uacfc \uc800\uc7a5. mastery \uacc4\uc0b0\uc740 \uc788\uc73c\uba74 \uc774 \ud544\ub4dc \uc6b0\uc120. \uac80\ud1a0 v2 \ud68c\ucc28\uc5d0\uc11c \ucc44\uc6cc\uc9d0."
    }
  },
  "required": [
    "student_id",
    "problem_id"
  ]
}